npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# docs & claude files
CLAUDE.md
AGENTS.md
PROJECT-OVERVIEW.md
*.md
