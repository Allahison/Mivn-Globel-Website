# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# deployment artifacts
/namecheap-deploy/
/namecheap-standalone/
/deploy/
*.zip
*.rar
*.7z
*.tar
*.tar.gz

# misc
.DS_Store
*.pem

